# ── Variáveis de ambiente — CCP NEXATECH ─────────────────────────────────────
# Copie este arquivo para .env.local e preencha os valores reais
# NUNCA commite o .env.local no git

# URL pública do site (sem barra no final)
NEXT_PUBLIC_SITE_URL=https://ccpnexatech.com.br

# Modo de envio de e-mail: 'mailto' (padrão) ou 'resend'
EMAIL_MODE=mailto

# E-mail que receberá os contatos do formulário
CONTACT_EMAIL=ccpnexatech@gmail.com

# Chave da API Resend (necessária apenas quando EMAIL_MODE=resend)
# Obtenha em: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx